# Home Assistant — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values
# before running `docker compose up -d`.

# --- Timezone ----------------------------------------------------------------
# IANA timezone name. Used for logs, automations, and schedules.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Berlin

# --- Networking --------------------------------------------------------------
# Host interface the web UI is published on.
#   0.0.0.0     -> reachable from anything that can route to the NAS (LAN)
#   <nas-lan-ip> -> reachable from the LAN only (recommended on multi-homed NAS)
#   127.0.0.1   -> loopback only; use this when HA sits behind a reverse
#                  proxy running on the same host
HA_BIND_ADDR=0.0.0.0

# Host port the web UI is published on. The container always listens on
# 8123 internally; this only changes the host-side port mapping.
HA_BIND_PORT=8123
