# PostgreSQL — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values
# before running `docker compose up -d`.
# Generate strong passwords with e.g. `openssl rand -base64 32`.

# --- Superuser ---------------------------------------------------------------
# Used by the init scripts and by any admin tool you connect with.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-please-long-random-string

# Default maintenance database created at first boot. You normally do
# NOT store application data here — use one of the per-app databases
# defined by POSTGRES_MULTIPLE_DATABASES below.
POSTGRES_DB=postgres

# --- Per-app databases -------------------------------------------------------
# Comma-separated list. For each entry `foo`, the first-boot init script
# (initdb/01-create-databases.sh) will create:
#   * a login role     named `foo`
#   * a database       named `foo`, owned by that role
# Add / remove entries here, then recreate the data volume (or run the
# script manually) to apply the change. Each app should also have a
# matching `NN-init-<name>.sql` file in `initdb/` that creates its
# tables (see e.g. `initdb/02-init-whatsfordinner.sql`).
POSTGRES_MULTIPLE_DATABASES=whatsfordinner

# Per-database role passwords. Variable name = POSTGRES_<NAME>_PASSWORD
# with <NAME> uppercased and dashes replaced by underscores. If a
# matching variable is missing, the init script falls back to
# POSTGRES_PASSWORD (fine for dev, NOT recommended on the NAS).
POSTGRES_WHATSFORDINNER_PASSWORD=change-me-whatsfordinner

# --- Networking --------------------------------------------------------------
# Host loopback port the server is published on. Keep this on 127.0.0.1
# only (see compose.yaml). Remote access should go through SSH tunnels
# or a reverse proxy with TLS — never expose 5432 to the LAN/Internet.
POSTGRES_BIND_PORT=5432
